**/*.gif
**/*.webp
**/*.ico
**/*.pdf
**/*.mp4
**/*.mov
**/*.zip
**/*.apk
**/*.aab
**/*.ipa
**/*.dSYM/**

# Локальные дампы и секреты
**/.env
**/.env.*
**/neon_dump_*.sql
my_serve_chat_test/neon_dump_*.sql
